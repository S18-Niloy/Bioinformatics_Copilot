# Environment Configuration
# Copy this file to .env and update the values for your deployment

# Deployment environment (development | production)
ENVIRONMENT=development

# Database URL (SQLite for dev, PostgreSQL recommended for production)
DATABASE_URL=sqlite:///./biocopilot.db

# JWT Secret Key (minimum 32 characters; generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=your-super-secret-key-minimum-32-characters-generate-with-secrets

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted Hosts (comma-separated list of allowed hostnames)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# API Settings
API_WORKERS=4

# Logging Level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Optional: Database connection pooling (for production databases)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
